# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=local                        # local | dev | prod
LOG_LEVEL=INFO

# ─── DynamoDB ─────────────────────────────────────────────────────────────────
DYNAMODB_TABLE_NAME=greyhound-facts
DYNAMODB_ENDPOINT_URL=               # leave blank in AWS; set to http://localhost:8000 for DynamoDB Local

# ─── Auth ─────────────────────────────────────────────────────────────────────
# For local dev, set a plain-text key here.
# In dev/prod, leave blank — the value is fetched from Secrets Manager at cold start.
ADMIN_API_KEY=supersecret-local-key
SECRETS_MANAGER_SECRET_NAME=         # e.g. greyhound-facts/admin-api-key

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY are picked up automatically
# from ~/.aws/credentials or the Lambda execution role — do not set in prod.

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
